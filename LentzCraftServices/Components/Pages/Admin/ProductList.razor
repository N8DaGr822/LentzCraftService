@page "/admin/products"
@attribute [Authorize]
@inject IProductRepository ProductRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Manage Products - Admin</PageTitle>

<div class="admin-page">
    <div class="container">
        <div class="admin-header">
            <h1 class="page-title">Manage Products</h1>
            <a href="/admin/products/new" class="btn-primary">Add New Product</a>
        </div>

        <div class="admin-filters">
            <input type="text" @bind="searchTerm" @bind:event="oninput" @bind:after="LoadProducts" placeholder="Search products..." class="search-input" />
            <select @bind="filterCategory" @bind:after="LoadProducts" class="filter-select">
                <option value="">All Categories</option>
                @foreach (var cat in Enum.GetValues<ProductCategory>())
                {
                    <option value="@cat.ToString()">@cat.GetDisplayName()</option>
                }
            </select>
            <select @bind="filterStatus" @bind:after="LoadProducts" class="filter-select">
                <option value="">All Status</option>
                @foreach (var status in Enum.GetValues<ProductStatus>())
                {
                    <option value="@status.ToString()">@status.GetDisplayName()</option>
                }
            </select>
        </div>

        @if (IsFiltered)
        {
            <p class="filter-notice">Reordering is disabled while filters are active. Clear all filters to change product order.</p>
        }

        @if (productsList != null && productsList.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width: 90px;">Order</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Public</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < productsList.Count; i++)
                    {
                        var product = productsList[i];
                        var index = i;
                        <tr>
                            <td>
                                @if (!IsFiltered)
                                {
                                    <div class="order-buttons">
                                        @if (index > 0)
                                        {
                                            <button @onclick="() => MoveUp(index)" class="btn-order" title="Move Up">&#9650;</button>
                                        }
                                        @if (index < productsList.Count - 1)
                                        {
                                            <button @onclick="() => MoveDown(index)" class="btn-order" title="Move Down">&#9660;</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">--</span>
                                }
                            </td>
                            <td>@product.Name</td>
                            <td>@product.Category.GetDisplayName()</td>
                            <td>@product.Status.GetDisplayName()</td>
                            <td>@(product.Price?.ToString("C") ?? "N/A")</td>
                            <td>@product.Quantity</td>
                            <td>@(product.IsPublic ? "Yes" : "No")</td>
                            <td>
                                <a href="/admin/products/@product.Id" class="btn-small">Edit</a>
                                @if (confirmDeleteId == product.Id)
                                {
                                    <button @onclick="() => ConfirmDelete(product.Id)" class="btn-small btn-danger">Confirm</button>
                                    <button @onclick="CancelDelete" class="btn-small btn-secondary">Cancel</button>
                                }
                                else
                                {
                                    <button @onclick="() => RequestDelete(product.Id)" class="btn-small btn-danger">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No products found.</p>
        }
    </div>
</div>

@code {
    private List<Product>? productsList;
    private string searchTerm = "";
    private string filterCategory = "";
    private string filterStatus = "";
    private int? confirmDeleteId;

    private bool IsFiltered => !string.IsNullOrEmpty(searchTerm)
        || !string.IsNullOrEmpty(filterCategory)
        || !string.IsNullOrEmpty(filterStatus);

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        IEnumerable<Product> allProducts;

        if (!string.IsNullOrEmpty(searchTerm))
        {
            allProducts = await ProductRepository.SearchAsync(searchTerm);
        }
        else
        {
            allProducts = await ProductRepository.GetAllAsync();
        }

        if (!string.IsNullOrEmpty(filterCategory) && Enum.TryParse<ProductCategory>(filterCategory, out var category))
        {
            allProducts = allProducts.Where(p => p.Category == category);
        }

        if (!string.IsNullOrEmpty(filterStatus) && Enum.TryParse<ProductStatus>(filterStatus, out var status))
        {
            allProducts = allProducts.Where(p => p.Status == status);
        }

        productsList = allProducts.OrderBy(p => p.DisplayOrder)
            .ThenByDescending(p => p.CreatedDate).ToList();
    }

    private async Task MoveUp(int index)
    {
        if (productsList == null || index <= 0) return;

        var product = productsList[index];
        var previousProduct = productsList[index - 1];
        await ProductRepository.SwapDisplayOrderAsync(product.Id, previousProduct.Id);
        await LoadProducts();
    }

    private async Task MoveDown(int index)
    {
        if (productsList == null || index < 0 || index >= productsList.Count - 1) return;

        var product = productsList[index];
        var nextProduct = productsList[index + 1];
        await ProductRepository.SwapDisplayOrderAsync(product.Id, nextProduct.Id);
        await LoadProducts();
    }

    private void RequestDelete(int id)
    {
        confirmDeleteId = id;
    }

    private void CancelDelete()
    {
        confirmDeleteId = null;
    }

    private async Task ConfirmDelete(int id)
    {
        await ProductRepository.DeleteAsync(id);
        confirmDeleteId = null;
        await LoadProducts();
    }
}
