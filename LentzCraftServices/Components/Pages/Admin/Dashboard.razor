@page "/admin"
@attribute [Authorize]
@inject IProductRepository ProductRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Admin Dashboard - Lentz Crafts & Services</PageTitle>

<div class="admin-page">
    <div class="container">
        <h1 class="page-title">Admin Dashboard</h1>
        
        <div class="dashboard-stats">
            <div class="stat-card">
                <h3>Total Items</h3>
                <p class="stat-value">@totalItems</p>
            </div>
            @foreach (var kvp in statusCounts)
            {
                <div class="stat-card">
                    <h3>@kvp.Key.GetDisplayName()</h3>
                    <p class="stat-value">@kvp.Value</p>
                </div>
            }
        </div>
        
        <div class="admin-actions">
            <a href="/admin/products" class="btn-primary">Manage Products</a>
        </div>
    </div>
</div>

@code {
    private int totalItems = 0;
    private Dictionary<ProductStatus, int> statusCounts = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var allProducts = await ProductRepository.GetAllAsync();
            var productList = allProducts.ToList();
            totalItems = productList.Count;
            statusCounts = Enum.GetValues<ProductStatus>()
                .ToDictionary(s => s, s => productList.Count(p => p.Status == s));
        }
        catch (Exception ex) when (IsDatabaseQuotaException(ex))
        {
            Navigation.NavigateTo("/DatabaseUnavailable");
        }
    }

    private static bool IsDatabaseQuotaException(Exception ex)
    {
        var message = ex.Message + (ex.InnerException != null ? " " + ex.InnerException.Message : "");
        return message.Contains("reached the monthly free amount allowance", StringComparison.OrdinalIgnoreCase);
    }
}

