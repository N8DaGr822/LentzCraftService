@page "/"
@using LentzCraftServices.Domain.Enums
@inject IProductRepository ProductRepository
@rendermode InteractiveServer

<PageTitle>Lentz Crafts & Services - Handcrafted Excellence</PageTitle>

<!-- Hero Banner Section -->
<div class="hero-banner-section">
    <div class="hero-banner-overlay">
        <div class="hero-banner-content">
            <h1 class="hero-banner-title">Handcrafted. Reliable. Local.</h1>
            <p class="hero-banner-tagline">Quality Craft & Home Services You Can Trust</p>
            <div class="hero-banner-buttons">
                <a href="/contact" class="btn-hero btn-hero-primary">Request a Quote</a>
                <a href="/products" class="btn-hero btn-hero-secondary">View Our Work</a>
            </div>
        </div>
    </div>
    <div class="hero-banner-image">
        <img src="/images/Banner.png" alt="Lentz Crafts & Services - Handcrafted Excellence" class="banner-image" />
    </div>
</div>

<!-- Our Services Section -->
<div class="services-section">
    <div class="container">
        <h2 class="section-heading">Our Services</h2>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-image">
                    <div class="service-image-placeholder">
                        <img src="/images/handymantools.png" alt="Handyman Services" class="service-image-img" />
                    </div>
                </div>
                <div class="service-content">
                    <h3 class="service-title">Handyman Services</h3>
                    <ul class="service-features">
                        <li>Repairs & Installations</li>
                        <li>Home Maintenance</li>
                        <li>Small Remodels</li>
                    </ul>
                    <a href="/contact" class="btn-service btn-service-green">Learn More</a>
                </div>
            </div>

            <div class="service-card">
                <div class="service-image">
                    <div class="service-image-placeholder">
                        @if (woodworkingImage != null)
                        {
                            <img src="@woodworkingImage" alt="Woodworking and Engraving Services" class="service-image-img" />
                        }
                        else
                        {
                            <img src="/images/engraving.png" alt="Woodworking and Engraving Services" class="service-image-img" />
                        }
                    </div>
                </div>
                <div class="service-content">
                    <h3 class="service-title">Woodworking & Engraving</h3>
                    <ul class="service-features">
                        <li>Custom Woodwork</li>
                        <li>Personalized Gifts</li>
                        <li>Home Décor</li>
                    </ul>
                    <a href="/products" class="btn-service btn-service-brown">Learn More</a>
                </div>
            </div>

            <div class="service-card">
                <div class="service-image">
                    <div class="service-image-placeholder">
                        @if (crochetImage != null)
                        {
                            <img src="@crochetImage" alt="Crochet and Handmade Goods" class="service-image-img" />
                        }
                        else
                        {
                            <img src="/images/crochet.png" alt="Crochet and Handmade Goods" class="service-image-img" />
                        }
                    </div>
                </div>
                <div class="service-content">
                    <h3 class="service-title">Crochet & Handmade Goods</h3>
                    <ul class="service-features">
                        <li>Custom Creations</li>
                        <li>Hats & Gifts</li>
                        <li>Seasonal Items</li>
                    </ul>
                    <a href="/products" class="btn-service btn-service-brown">Learn More</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Why Choose Us Section -->
<div class="why-choose-section">
    <div class="container">
        <h2 class="section-heading">Why Choose Lentz Craft & Services?</h2>
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon">🏠</div>
                <h3 class="feature-title">Locally Owned</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">✓</div>
                <h3 class="feature-title">Quality Workmanship</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">❤️</div>
                <h3 class="feature-title">Attention to Detail</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">💰</div>
                <h3 class="feature-title">Honest Pricing</h3>
            </div>
        </div>
    </div>
</div>

<!-- Our Work Gallery Section -->
<div class="work-gallery-section">
    <div class="container">
        <h2 class="section-heading section-heading-light">Our Work: Crafted with Care</h2>
        @if (galleryProducts != null && galleryProducts.Any())
        {
            <div class="gallery-grid">
                @foreach (var product in galleryProducts)
                {
                    var image = product.Images?.FirstOrDefault(i => i.IsPrimary) ?? product.Images?.FirstOrDefault();
                    if (image != null)
                    {
                        var imageUrl = image.ImageUrl?.Replace(" ", "%20") ?? "";
                        <div class="gallery-item">
                            <a href="/products/@product.Id">
                                <div class="gallery-image-placeholder">
                                    <img src="@imageUrl" alt="@product.Name" class="gallery-image" loading="lazy" />
                                </div>
                            </a>
                        </div>
                    }
                }
            </div>
        }
        <div class="gallery-cta">
            <a href="/products" class="btn-gallery">View Gallery</a>
        </div>
    </div>
</div>

<!-- Ready to Get Started Section -->
<div class="cta-section">
    <div class="container">
        <h2 class="section-heading section-heading-light">Ready to Get Started?</h2>
        <p class="cta-tagline">Contact us today for a free quote!</p>
        <a href="/contact" class="btn-cta">Get a Free Quote</a>
    </div>
</div>

@code {
    private List<Product>? galleryProducts;
    private string? woodworkingImage;
    private string? crochetImage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var products = await ProductRepository.GetPublicProductsAsync(includeImages: true);
            var productsWithImages = products
                .Where(p => p.Images != null && p.Images.Any())
                .ToList();

            // Service card images — pick the first product with an image from each category
            woodworkingImage = GetPrimaryImageUrl(productsWithImages, ProductCategory.Woodworking)
                            ?? GetPrimaryImageUrl(productsWithImages, ProductCategory.Engraving);

            crochetImage = GetPrimaryImageUrl(productsWithImages, ProductCategory.Crochet);

            // Gallery section — 3 most recent products with images
            galleryProducts = productsWithImages.Take(3).ToList();
        }
        catch
        {
            // Gracefully handle database errors — page renders with static fallback images
            galleryProducts = new List<Product>();
        }
    }

    private string? GetPrimaryImageUrl(List<Product> products, ProductCategory category)
    {
        var product = products.FirstOrDefault(p => p.Category == category);
        if (product == null) return null;

        var image = product.Images?.FirstOrDefault(i => i.IsPrimary)
                 ?? product.Images?.FirstOrDefault();

        return image?.ImageUrl?.Replace(" ", "%20");
    }
}
