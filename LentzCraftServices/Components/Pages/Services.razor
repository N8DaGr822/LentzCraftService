@page "/services"
@rendermode InteractiveServer

<PageTitle>Services - Lentz Crafts & Services</PageTitle>

<div class="services-page">
    <div class="container">
        <h1 class="services-page-title">Our Services</h1>
        <p class="services-page-intro">
            At Lentz Crafts & Services, we offer a wide range of handcrafted goods and home services. 
            From custom woodworking to home repairs, we bring quality craftsmanship and reliable service to every project.
        </p>

        <!-- Handyman Services Section -->
        <section class="service-detail-section">
            <div class="service-detail-header">
                <div class="service-detail-icon">🔧</div>
                <h2 class="service-detail-title">Handyman Services</h2>
            </div>
            <div class="service-detail-content">
                <div class="service-detail-image">
                    <img src="/images/handymantools.png" alt="Handyman Services" class="service-detail-img" />
                </div>
                <div class="service-detail-text">
                    <p class="service-detail-description">
                        Need reliable home repairs and improvements? Our handyman services cover a wide range of household needs, 
                        from quick fixes to small remodeling projects. We're committed to quality workmanship and honest pricing.
                    </p>
                    <h3 class="service-detail-subtitle">What We Offer:</h3>
                    <ul class="service-detail-list">
                        <li><strong>Repairs & Installations</strong> - Fixing what's broken and installing new fixtures, hardware, and appliances</li>
                        <li><strong>Home Maintenance</strong> - Regular upkeep tasks to keep your home in great condition</li>
                        <li><strong>Small Remodels</strong> - Bathroom updates, kitchen improvements, and other renovation projects</li>
                        <li><strong>General Carpentry</strong> - Custom shelving, trim work, and built-in solutions</li>
                        <li><strong>Tile Work</strong> - Professional tile installation and repair for bathrooms, kitchens, and floors</li>
                    </ul>
                    <div class="service-detail-cta">
                        <a href="/contact" class="btn-service-detail">Get a Quote</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Woodworking & Engraving Section -->
        <section class="service-detail-section service-detail-section-alt">
            <div class="service-detail-header">
                <div class="service-detail-icon">🪵</div>
                <h2 class="service-detail-title">Woodworking & Engraving</h2>
            </div>
            <div class="service-detail-content service-detail-content-reverse">
                <div class="service-detail-text">
                    <p class="service-detail-description">
                        Transform quality hardwoods into timeless pieces that add warmth and character to your home. 
                        Our woodworking services combine traditional craftsmanship with modern design, creating functional 
                        and beautiful pieces built to last.
                    </p>
                    <h3 class="service-detail-subtitle">Woodworking Services:</h3>
                    <ul class="service-detail-list">
                        <li><strong>Custom Furniture</strong> - Tables, chairs, shelves, and storage solutions tailored to your space</li>
                        <li><strong>Kitchen Accessories</strong> - Cutting boards, serving trays, utensil holders, and more</li>
                        <li><strong>Home Décor</strong> - Picture frames, wall art, decorative boxes, and accent pieces</li>
                        <li><strong>Functional Items</strong> - Tool organizers, desk accessories, and organizational solutions</li>
                    </ul>
                    <h3 class="service-detail-subtitle">Engraving Services:</h3>
                    <ul class="service-detail-list">
                        <li><strong>Personalized Gifts</strong> - Names, dates, quotes, and custom messages on wood, metal, or glass</li>
                        <li><strong>Custom Signs</strong> - House numbers, welcome signs, and decorative plaques</li>
                        <li><strong>Memorial Items</strong> - Keepsakes and commemorative pieces for special occasions</li>
                        <li><strong>Business Branding</strong> - Custom logos and text for business signage and promotional items</li>
                    </ul>
                    <div class="service-detail-cta">
                        <a href="/products?category=Woodworking" class="btn-service-detail">View Our Work</a>
                        <a href="/contact" class="btn-service-detail btn-service-detail-secondary">Request Custom Project</a>
                    </div>
                </div>
                <div class="service-detail-image">
                    <img src="/images/engraving.png" alt="Woodworking & Engraving" class="service-detail-img" />
                </div>
            </div>
        </section>

        <!-- Crochet & Handmade Goods Section -->
        <section class="service-detail-section">
            <div class="service-detail-header">
                <div class="service-detail-icon">🧶</div>
                <h2 class="service-detail-title">Crochet & Handmade Goods</h2>
            </div>
            <div class="service-detail-content">
                <div class="service-detail-image">
                    <img src="/images/crochet.png" alt="Crochet & Handmade Goods" class="service-detail-img" />
                </div>
                <div class="service-detail-text">
                    <p class="service-detail-description">
                        Every stitch is made with care and attention to detail. Our crochet creations bring comfort, 
                        warmth, and a personal touch to your home. From cozy blankets to playful amigurumi, each piece 
                        is crafted by hand with quality yarns and thoughtful design.
                    </p>
                    <h3 class="service-detail-subtitle">What We Create:</h3>
                    <ul class="service-detail-list">
                        <li><strong>Blankets & Throws</strong> - Warm, cozy blankets in various patterns and sizes</li>
                        <li><strong>Hats & Accessories</strong> - Custom beanies, scarves, and winter wear</li>
                        <li><strong>Amigurumi</strong> - Handcrafted stuffed animals and decorative figures</li>
                        <li><strong>Home Décor</strong> - Pillows, wall hangings, and decorative accents</li>
                        <li><strong>Seasonal Items</strong> - Holiday-themed decorations and gifts</li>
                        <li><strong>Custom Orders</strong> - Personalized items made to your specifications</li>
                    </ul>
                    <div class="service-detail-cta">
                        <a href="/products?category=Crochet" class="btn-service-detail">Browse Gallery</a>
                        <a href="/contact" class="btn-service-detail btn-service-detail-secondary">Request Custom Item</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Why Choose Us Section -->
        <section class="services-why-choose">
            <h2 class="section-heading">Why Choose Lentz Crafts & Services?</h2>
            <div class="services-benefits-grid">
                <div class="service-benefit">
                    <div class="service-benefit-icon">✓</div>
                    <h3>Proven Experience</h3>
                    <p>Years of hands-on experience in craftsmanship and home services</p>
                </div>
                <div class="service-benefit">
                    <div class="service-benefit-icon">🏠</div>
                    <h3>Local & Reliable</h3>
                    <p>Locally owned and operated, committed to your satisfaction</p>
                </div>
                <div class="service-benefit">
                    <div class="service-benefit-icon">❤️</div>
                    <h3>Quality Craftsmanship</h3>
                    <p>Every project is completed with attention to detail and pride in workmanship</p>
                </div>
                <div class="service-benefit">
                    <div class="service-benefit-icon">💰</div>
                    <h3>Honest Pricing</h3>
                    <p>Fair, transparent pricing with no hidden fees or surprises</p>
                </div>
            </div>
        </section>

        <!-- Call to Action -->
        <section class="services-cta">
            <h2 class="section-heading section-heading-light">Ready to Get Started?</h2>
            <p class="services-cta-text">Have a project in mind? We'd love to hear from you!</p>
            <div class="services-cta-buttons">
                <a href="/contact" class="btn-cta">Get a Free Quote</a>
                <a href="/products" class="btn-cta btn-cta-secondary">View Our Portfolio</a>
            </div>
        </section>
    </div>
</div>
