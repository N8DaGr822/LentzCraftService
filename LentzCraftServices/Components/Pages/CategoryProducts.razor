@page "/products/{CategoryName}"
@inject IProductRepository ProductRepository
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@CategoryDisplayName - Lentz Crafts & Services</PageTitle>

<div class="category-products-page">
    <div class="container">
        <h1 class="page-title">@CategoryDisplayName</h1>
        
        @if (useStaticFallback)
        {
            <div class="static-gallery-notice">
                <p>Our product catalog is temporarily unavailable. Here's a preview of our work:</p>
            </div>
            <div class="product-grid">
                @foreach (var img in GetStaticImagesForCategory(CategoryName))
                {
                    <div class="product-card">
                        <img src="@img.Url" alt="@img.Name" class="product-image" loading="lazy" />
                        <div class="product-info">
                            <h3 class="product-name">@img.Name</h3>
                        </div>
                    </div>
                }
            </div>
        }
        else if (products != null && products.Any())
        {
            <div class="product-grid">
                @foreach (var product in products)
                {
                    <div class="product-card">
                        @if (product.Images != null && product.Images.Any(i => i.IsPrimary))
                        {
                            var primaryImage = product.Images.First(i => i.IsPrimary);
                            var imageUrl = primaryImage.ImageUrl?.Replace(" ", "%20") ?? "";
                            <img src="@imageUrl" alt="@product.Name" class="product-image" loading="lazy" />
                        }
                        else if (product.Images != null && product.Images.Any())
                        {
                            var firstImage = product.Images.First();
                            var imageUrl = firstImage.ImageUrl?.Replace(" ", "%20") ?? "";
                            <img src="@imageUrl" alt="@product.Name" class="product-image" loading="lazy" />
                        }
                        else
                        {
                            <div class="product-image-placeholder">No Image</div>
                        }
                        <div class="product-info">
                            <h3 class="product-name">@product.Name</h3>
                            <p class="product-status">@product.Status.GetDisplayName()</p>
                            @if (product.Price.HasValue)
                            {
                                <p class="product-price">$@product.Price.Value.ToString("F2")</p>
                            }
                            <a href="/products/@product.Id" class="btn-secondary">View Details</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="no-products">No products found in this category.</p>
        }
    </div>
</div>

@code {
    [Parameter] public string CategoryName { get; set; } = "";
    
    private IEnumerable<Product>? products;
    private bool useStaticFallback = false;
    private string CategoryDisplayName
    {
        get
        {
            if (Enum.TryParse<ProductCategory>(CategoryName, true, out var cat))
                return cat.GetDisplayName();
            return "Products";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Enum.TryParse<ProductCategory>(CategoryName, true, out var category))
            {
                var allProducts = await ProductRepository.GetByCategoryAsync(category, includeImages: true);
                products = allProducts.Where(p => p.IsPublic).OrderByDescending(p => p.CreatedDate).ToList();
            }
            else
            {
                products = new List<Product>();
            }
        }
        catch (Exception ex) when (IsDatabaseQuotaException(ex))
        {
            useStaticFallback = true;
        }
    }

    private static bool IsDatabaseQuotaException(Exception ex)
    {
        var message = ex.Message + (ex.InnerException != null ? " " + ex.InnerException.Message : "");
        return message.Contains("reached the monthly free amount allowance", StringComparison.OrdinalIgnoreCase);
    }

    private record StaticImage(string Url, string Name);

    private static List<StaticImage> GetStaticImagesForCategory(string category) =>
    [
        new("/images/fallback/BestMomEverBox1.jpg", "Best Mom Ever Box"),
        new("/images/fallback/DoubleBench.jpg", "Double Bench"),
        new("/images/fallback/DoubleBench1.jpg", "Double Bench"),
        new("/images/fallback/DoubleBench2.jpg", "Double Bench"),
        new("/images/fallback/TreeAI.png", "Tree"),
        new("/images/fallback/WineBottleHolder.jpg", "Wine Bottle Holder"),
        new("/images/fallback/WineBottleHolder1.jpg", "Wine Bottle Holder"),
    ];
}

